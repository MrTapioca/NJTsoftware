<hr class="my-4" />

<form id="contact-form">

    <div class="row" id="contact">
        <div class="col">
            <h1 class="text-primary text-shadow">Contact Me</h1>
        </div>

        <div class="col-2 ml-3 d-flex justify-content-end align-items-center">
            <span class="far fa-comment fa-2x text-primary text-shadow"></span>
        </div>
    </div>

    <div class="row">
        <div class="col">
            <p class="lead text-justify hyphenate">
                Are you interested in working together? Send me a message. I look forward to hearing from you.
            </p>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-lg-8 col-xl-6">
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <input asp-for="Message.Name" class="form-control" placeholder="Name" required />
                        <span asp-validation-for="Message.Name" class="text-danger small"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <input asp-for="Message.Email" class="form-control" placeholder="E-mail" required />
                        <span asp-validation-for="Message.Email" class="text-danger small"></span>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col">
                    <div class="form-group">
                        <textarea asp-for="Message.MessageText" class="form-control" rows="4" placeholder="Message" required></textarea>
                        <span asp-validation-for="Message.MessageText" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary" data-submit="true">
                        <div data-sending="false">Send Message</div>
                        <div data-sending="true">
                            <span class="mr-3">Sending...</span>
                            <span class="spinner-border spinner-border-sm" role="status">
                                <span class="sr-only">Sending...</span>
                            </span>
                        </div>
                    </button>
                </div>
            </div>

            <div class="row mt-3" id="contact-form-sent">
                <div class="col">
                    <div class="alert alert-success alert-dismissible" role="alert">
                        <span>
                            Message sent! I will get back to you as soon as possible.
                            Thank you for reaching out.
                        </span>
                        <button type="button" class="close" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                </div>
            </div>

            <div class="row mt-3" id="contact-form-error">
                <div class="col">
                    <div class="alert alert-danger alert-dismissible" role="alert">
                        <span>
                            I'm terribly sorry, but your message could not be sent for some odd reason.
                            Please try again or send me an email directly. Thank you!
                        </span>
                        <button type="button" class="close" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                </div>
            </div>

        </div>

    </div>

</form>